{
  "name": "mb4it/logger",
  "description": "File-based PSR-3 logger with channel support.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "psr/log": "^3.0",
    "mb4it/filesystem": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "MB\\Logger\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MB\\Logger\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
